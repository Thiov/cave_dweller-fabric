# Keep the libs dir as a placeholder but don't track downloaded jars.
# The build expects GeckoLib (and for 1.21.10 also fabric-api) jars in libs/;
# users should download them themselves from Modrinth (see READMEs).
**/libs/*.jar
!**/libs/.gitkeep
.envrc
